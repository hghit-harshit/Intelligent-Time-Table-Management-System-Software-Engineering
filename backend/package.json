{
  "name": "timetable-backend",
  "version": "1.0.0",
  "description": "Intelligent Timetable Management System Backend",
  "main": "src/server.ts",
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "tsx src/server.ts",
    "dev": "tsx watch src/server.ts",
    "seed:slots:inside": "tsx scripts/seedSlots.ts",
    "seed:scheduler-test:inside": "tsx scripts/seedSchedulerTestData.ts",
    "seed:notifications:inside": "tsx scripts/seedNotifications.ts",
    "seed:exams:inside": "tsx scripts/seedExamSchedules.ts",
    "seed:enrollments:inside": "tsx scripts/seedStudentEnrollments.ts",
    "seed:all:inside": "npm run db-setup:inside && npm run seed:slots:inside && npm run seed:scheduler-test:inside && npm run seed:enrollments:inside && npm run seed:notifications:inside && npm run seed:exams:inside",
    "seed:nice-timetable:inside": "tsx scripts/seedNiceTimetable.ts",
    "db-setup:inside": "tsx scripts/seedDefaultUsers.ts",
    "seed:slots": "docker compose -f docker-compose.dev.yml exec backend npm run seed:slots:inside",
    "seed:scheduler-test": "docker compose -f docker-compose.dev.yml exec backend npm run seed:scheduler-test:inside",
    "seed:all": "docker compose -f docker-compose.dev.yml exec backend npm run seed:all:inside",
    "seed:slots:docker": "npm run seed:slots",
    "seed:scheduler-test:docker": "npm run seed:scheduler-test",
    "seed:all:docker": "npm run seed:all"
  },
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.6",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "jsonwebtoken": "^9.0.3",
    "mongoose": "^8.0.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/mongoose": "^5.11.96",
    "@types/node": "^25.6.0",
    "nodemon": "^3.0.2",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2"
  }
}
