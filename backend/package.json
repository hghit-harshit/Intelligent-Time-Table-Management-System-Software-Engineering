{
  "name": "timetable-backend",
  "version": "1.0.0",
  "description": "Intelligent Timetable Management System Backend",
  "main": "server.js",
  "type": "module",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "seed:slots": "node scripts/seedSlots.js",
    "seed:scheduler-test": "node scripts/seedSchedulerTestData.js",
    "test": "NODE_OPTIONS=--experimental-vm-modules jest --forceExit --detectOpenHandles",
    "test:scheduler": "NODE_OPTIONS=--experimental-vm-modules jest services/scheduler/__tests__/scheduleSolver.test.js --forceExit --detectOpenHandles --verbose"
  },
  "dependencies": {
    "cors": "^2.8.6",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "mongoose": "^8.0.3"
  },
  "devDependencies": {
    "@jest/globals": "^29.7.0",
    "jest": "^29.7.0",
    "nodemon": "^3.0.2"
  }
}
